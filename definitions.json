{
  "rabbit_version": "3.12.0",
  "users": [
    {
      "name": "logistics_app",
      "password": "logistics_pass",
      "tags": ["administrator"]
    }
  ],
  "vhosts": [
    {
      "name": "logistics"
    }
  ],
  "permissions": [
    {
      "user": "logistics_app",
      "vhost": "logistics",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    }
  ],
  "policies": [],
  "exchanges": [
    {
      "name": "tracking.exchange",
      "vhost": "logistics",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "tracking.dlx",
      "vhost": "logistics",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    }
  ],
  "queues": [
    {
      "name": "tracking.delivery.updates",
      "vhost": "logistics",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "tracking.dlx",
        "x-dead-letter-routing-key": "delivery.update"
      }
    },
    {
      "name": "tracking.delivery.dlq",
      "vhost": "logistics",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "bindings": [
    {
      "source": "tracking.exchange",
      "vhost": "logistics",
      "destination": "tracking.delivery.updates",
      "destination_type": "queue",
      "routing_key": "delivery.update",
      "arguments": {}
    },
    {
      "source": "tracking.dlx",
      "vhost": "logistics",
      "destination": "tracking.delivery.dlq",
      "destination_type": "queue",
      "routing_key": "delivery.update",
      "arguments": {}
    }
  ]
}
